# ZeroBot - 0G Mainnet Telegram Bot
# Copy to .env and fill in your values

# --- Telegram ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# --- 0G Network (mainnet) ---
OG_RPC_URL=https://evmrpc.0g.ai
OG_CHAIN_ID=480
OG_EXPLORER=https://chainscan.0g.ai

# --- 0G Storage ---
OG_STORAGE_INDEXER=https://indexer-storage.0g.ai

# --- 0G Compute (optional - for buy_compute) ---
# Replace with real compute provider address once 0G publishes it
OG_COMPUTE_PROVIDER_ADDRESS=0x0000000000000000000000000000000000000000

# --- Wallet Encryption ---
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WALLET_ENCRYPTION_KEY=

# --- Database ---
DATABASE_PATH=./data/zerobot.db

# --- Price feed (optional) ---
COINGECKO_API_KEY=

# --- Render ---
# Render sets PORT automatically; default is 10000
PORT=10000
